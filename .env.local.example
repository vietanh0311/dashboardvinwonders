# Copy file này thành .env.local rồi điền giá trị thật.

# Mật khẩu chung để vào dashboard (trang /login). Không set = không khoá trang.
DASHBOARD_PASSWORD=

# Tuỳ chọn: override base URL của VC Creator Admin API.
# Mặc định: https://vcreator-admin-api.koc.com.vn
# VC_API_BASE_URL=

# Supabase (dùng để lưu lịch sử snapshot hàng ngày - xem supabase-schema.sql).
# CHỈ dùng server-side (route handlers) - KHÔNG bao giờ được expose ra client,
# không thêm tiền tố NEXT_PUBLIC_.
# Lấy ở Supabase Dashboard -> Project Settings -> API.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Tuỳ chọn nhưng NÊN set ở máy chạy sync: connection string Postgres trực tiếp
# (Project Settings -> Database -> Connection string -> URI). Chỉ dùng để
# refresh_anomaly_cache() sau mỗi lần sync (xem scripts/sync.ts) - query đó
# nặng hơn statement_timeout 8s mà PostgREST/anon-key áp cho mọi request qua
# Supabase client, nên phải gọi qua kết nối Postgres thẳng. Thiếu biến này thì
# sync vẫn chạy bình thường, chỉ bỏ qua bước cập nhật anomaly cache.
# SUPABASE_DB_URL=

# Tài khoản VC để sync TỰ ĐĂNG NHẬP lấy token (xem lib/vcAuth.ts) - không phải
# dán token tay nữa.
#
# CHỈ set ở máy chạy sync (máy local có VPN), KHÔNG set trên Vercel: dashboard
# không gọi VC API, và IP của Vercel cũng không nằm trong whitelist.
#
# BẮT BUỘC là tài khoản isRoot: true. Tài khoản thường bị 401 ở /users/<id> nên
# không lấy được profile creator (SĐT, hợp đồng, banned, thống kê tiền).
VC_STAFF_EMAIL=
VC_STAFF_PASSWORD=
